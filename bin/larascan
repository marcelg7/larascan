#!/usr/bin/env php
<?php
// larascan — Composer-installed CLI shim.
// Delegates to scripts/audit.php, which reads $argv directly and calls exit(main($argv)).
// The shim exists so `composer require --dev mjgapp/larascan` exposes `vendor/bin/larascan`.

$scriptDir = __DIR__ . '/../scripts';
$audit = $scriptDir . '/audit.php';

if (!is_file($audit)) {
    fwrite(STDERR, "larascan: cannot locate scanner at {$audit}\n");
    exit(1);
}

require $audit;
